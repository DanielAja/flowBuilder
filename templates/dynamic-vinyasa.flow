{
  "name": "Dynamic Vinyasa Template",
  "description": "A vinyasa-style class performed in a heated room (typically 95-98 degrees with added humidity). It's characterized by a dynamic flow that links breath to movement. While instructors have the creative freedom to vary the sequence, the class generally follows this framework",
  "asanas": [
    {
      "name": "childs-pose",
      "english": "Child's Pose",
      "sanskrit": "Balasana",
      "duration": 120,
      "difficulty": "Beginner",
      "side": "Front",
      "description": "Resting pose gently stretching hips, thighs, ankles, and back. Calms the mind and nervous system. Promotes release and surrender.",
      "tags": [
        "Floor",
        "Resting",
        "Restorative",
        "Stretch",
        "Calming",
        "Forward Fold"
      ],
      "chakras": [
        "Third Eye",
        "Root"
      ]
    },
    {
      "name": "table-top",
      "english": "Table Top",
      "sanskrit": "Bharmanasana",
      "duration": 15,
      "difficulty": "Beginner",
      "side": "Front",
      "description": "A neutral position on hands and knees with a flat back. Foundation for cat-cow, bird dog, and transitions like Downward Dog.",
      "tags": [
        "Foundation",
        "Neutral",
        "Kneeling"
      ],
      "chakras": [
        "Sacral",
        "Root"
      ]
    },
    {
      "name": "cat-pose",
      "english": "Cat Pose",
      "sanskrit": "Marjaryasana",
      "duration": 15,
      "difficulty": "Beginner",
      "side": "Front",
      "description": "Performed on hands and knees, rounding the spine upward, tucking chin to chest. Stretches back torso and neck. Paired with Cow Pose.",
      "tags": [
